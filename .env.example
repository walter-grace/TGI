# TGI v1 — Environment template
# Copy to .env or .env.local and fill in your values

# Trello (required for Trello tracker)
TRELLO_API_KEY=your_api_key
TRELLO_API_TOKEN=your_api_token

# Agent provider — choose in WORKFLOW.md (provider: "openrouter" | "claude" | "openai")
OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...  # if using provider: "claude"
# OPENAI_API_KEY=sk-...         # if using provider: "openai" (also: Azure, vLLM, Bedrock proxy)

# Server
TGI_PORT=3199
TGI_LOG_LEVEL=info

# Optional: Web search (Tavily)
# TAVILY_API_KEY=tvly-...

# Optional: Discord notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
